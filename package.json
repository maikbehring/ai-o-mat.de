    "benchmark:question-29": "node scripts/cultural-bias-benchmark.mjs --only-questions=29 && node scripts/build-benchmark-rating-page.mjs --only-questions=29",
    "benchmark:question-31": "node scripts/cultural-bias-benchmark.mjs --only-questions=31 && node scripts/build-benchmark-rating-page.mjs --only-questions=31",
    "benchmark:question-35": "node scripts/cultural-bias-benchmark.mjs --only-questions=35 && node scripts/build-benchmark-rating-page.mjs --only-questions=35",
    "benchmark:question-41": "node scripts/cultural-bias-benchmark.mjs --only-questions=41 && node scripts/build-benchmark-rating-page.mjs --reclassify",
    "benchmark:question-42": "node scripts/cultural-bias-benchmark.mjs --only-questions=42 && node scripts/build-benchmark-rating-page.mjs --only-questions=42",
    "benchmark:questions-43-45": "node scripts/cultural-bias-benchmark.mjs --only-questions=43,44,45 && node scripts/build-benchmark-rating-page.mjs --only-questions=43,44,45",
