# Pflicht: API-Key aus dem mStudio (Organisation/Projekt → AI-Hosting)
MITTWALD_AI_API_KEY=sk-…

# Optional: Standard ist die offizielle mittwald-Base-URL
# MITTWALD_AI_BASE_URL=https://llm.aihosting.mittwald.de/v1

# Server-Port
PORT=8787

# Kommagetrennte Modell-IDs (müssen exakt zu /v1/models passen). Ohne gpt-oss/Qwen erscheinen
# diese nicht im Dropdown — sie sind im Playground bereits mit Doku-Presets verdrahtet.
# Für öffentliche Playgrounds die Liste bewusst kürzen.
PLAYGROUND_ALLOWED_MODELS=Ministral-3-14B-Instruct-2512,Devstral-Small-2-24B-Instruct-2512,gpt-oss-120b,Qwen3.5-122B-A10B-FP8,Qwen3.6-35B-A3B-FP8

# Rate-Limit (pro IP) — Werte erscheinen im UI-Hinweis bei 429 (z. B. „40 Chat-Nachrichten pro 15 Minuten“)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_CHAT=40

# Rate-Limit für Modellliste (pro IP)
RATE_LIMIT_MAX_MODELS=120

# JSON-Body maximal (Bytes)
MAX_BODY_BYTES=524288

# Max. Nachrichten pro Chat-Request (System + Verlauf); Schutz vor riesigen Prompts
# PLAYGROUND_MAX_MESSAGES=60

# CORS: Kommagetrennte Origins; * nur für lokale Tests
CORS_ORIGIN=http://localhost:5173

# Hinter Reverse-Proxy (X-Forwarded-For) — für echte Client-IPs bei Rate-Limit
TRUST_PROXY=0

# Öffentlicher Titel (optional)
PLAYGROUND_BRAND_TITLE=Mittwald KI-Playground

# Footer-/Sidebar-Links (nur gesetzte URLs erscheinen im UI)
# PLAYGROUND_LINK_IMPRESSUM_URL=https://example.com/impressum
# PLAYGROUND_LINK_IMPRESSUM_LABEL=Impressum
# PLAYGROUND_LINK_PRIVACY_URL=https://example.com/datenschutz
# PLAYGROUND_LINK_PRIVACY_LABEL=Datenschutz
# PLAYGROUND_LINK_TERMS_URL=https://example.com/nutzungsbedingungen
# PLAYGROUND_LINK_TERMS_LABEL=Nutzungsbedingungen
# PLAYGROUND_LINK_AI_HOSTING_URL=https://www.mittwald.de/mstudio/ai-hosting
# PLAYGROUND_LINK_AI_HOSTING_LABEL=AI Hosting
# PLAYGROUND_LINK_DOCS_URL=https://developer.mittwald.de/de/docs/v2/platform/aihosting/
# PLAYGROUND_LINK_DOCS_LABEL=Developer-Dokumentation
# PLAYGROUND_LINK_BUG_URL=https://github.com/org/repo/issues/new
# PLAYGROUND_LINK_BUG_LABEL=Bug melden

# Spracheingabe (Whisper über mittwald AI-Hosting)
# PLAYGROUND_WHISPER_MODEL=whisper-large-v3-turbo
# PLAYGROUND_WHISPER_LANGUAGE=de
# PLAYGROUND_MAX_AUDIO_BYTES=26214400
# RATE_LIMIT_MAX_TRANSCRIBE=30

# Websuche (Standard: DuckDuckGo, ohne API-Key)
# WEB_SEARCH_PROVIDER=duckduckgo
# WEB_SEARCH_MAX_RESULTS=5
# Optional: Mittwald-Modell für „Kurz-Google-Query“ aus Chat (sonst erstes erlaubtes Modell)
# WEB_SEARCH_QUERY_MODEL=Ministral-3-14B-Instruct-2512
# Google via SerpAPI (https://serpapi.com/dashboard) — empfohlen bei API-Key
# WEB_SEARCH_PROVIDER=serpapi
# WEB_SEARCH_SERPAPI_API_KEY=
# Optional: Google via Serper — WEB_SEARCH_PROVIDER=serper
# WEB_SEARCH_SERPER_API_KEY=
# Optional: Region/Sprache für Google (SerpAPI/Serper)
# WEB_SEARCH_GOOGLE_GL=de
# WEB_SEARCH_GOOGLE_HL=de
# WEB_SEARCH_GOOGLE_LOCATION=Germany
# Websuche: RATE_LIMIT_MAX_WEB_SEARCH=30

# Optional: EUrouter / Gemma 4 für scripts/cultural-bias-benchmark.mjs (npm run benchmark:culture)
# EUROUTER_API_KEY=eur_…
# EUROUTER_BASE_URL=https://api.eurouter.ai/api/v1
# BENCHMARK_MODEL_EUROUTER=gemma-4
# BENCHMARK_MODEL_EUROUTER_FALLBACK=gemma-3-27b-it
# Weitere EUrouter-Modelle: npm run benchmark:eurouter-extra
# (glm-5, nova-2-lite, claude-haiku-4.5 — siehe scripts/cultural-bias-benchmark.mjs)

# Optional: xAI Grok für scripts/cultural-bias-benchmark.mjs (npm run benchmark:grok-only)
# XAI_API_KEY=xai-…
# XAI_BASE_URL=https://api.x.ai/v1
# BENCHMARK_MODEL_GROK=grok-4.3
# BENCHMARK_LABEL_GROK=Grok 4.3
